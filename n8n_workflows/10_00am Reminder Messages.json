    {
      "parameters": {
        "jsCode": "// Access the nested array of task objects from the 'data' property of the single input item.\nconst tasks = items[0].json.data; \n\n// 1. Initialize an array to hold each formatted task string.\nconst formattedTasks = [];\n\n// 2. Define the base URL structure.\nconst BASE_URL = \"https://discord.com/channels/\";\n\n// 3. Iterate over the 'tasks' array.\n// This loop will run once for every task object in the 'data' array.\nif (Array.isArray(tasks)) {\n    for (const task of tasks) {\n        // Destructure the required IDs from the current task object.\n        const { user_id, guild_id, channel_id2, message_id } = task;\n\n        // Construct the full Discord URL for the message.\n        // We use template literals (backticks) for easy string construction.\n        const messageURL = `${BASE_URL}${guild_id}/${channel_id2}/${message_id}`;\n\n        // Construct the formatted string: <@UserID>: [Link Text](URL)\n        const taskString = `<@${user_id}>: [Click here to jump to task](${messageURL})`;\n\n        // Add the formatted string to our array.\n        formattedTasks.push(taskString);\n    }\n} else {\n    // Fallback error handling in case the array is empty or the structure is wrong.\n    return [{ json: { messageBody: \"Error: Task data structure incorrect or empty after Aggregate.\" } }];\n}\n\n// 4. Join all the task strings with two newline characters ('\\n\\n') for clean spacing.\nconst messageBody = formattedTasks.join('\\n\\n');\n\n// 5. Return the result in a property named 'messageBody' for the next node (Discord).\nreturn [{\n    json: {\n        messageBody: messageBody \n    }\n}];"
      },
