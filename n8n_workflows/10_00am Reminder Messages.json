    {
      "parameters": {
        "jsCode": "// Function to subtract business days\nfunction subtractBusinessDays(startDate, days) {\n    let date = DateTime.fromJSDate(startDate).startOf('day');\n    let remainingDays = days;\n\n    while (remainingDays > 0) {\n        date = date.minus({ days: 1 });\n        const weekday = date.weekday; // 1 (Monday) to 7 (Sunday)\n\n        // Check if it's a weekday (Monday=1 to Friday=5)\n        if (weekday >= 1 && weekday <= 5) {\n            remainingDays--;\n        }\n    }\n    return date.toISODate(); // Format to YYYY-MM-DD\n}\n\n// Get the current date and subtract 3 business days\nconst AgedDate = subtractBusinessDays(new Date(), 5);\n\n// The output of this node will contain the calculated date\nreturn [{\n  json: {\n    AgedDate: AgedDate\n  }\n}];"
      },
