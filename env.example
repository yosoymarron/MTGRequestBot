# Discord (from test application)
DISCORD_PUBLIC_KEY=your_test_app_public_key
DISCORD_BOT_TOKEN=your_test_app_bot_token
DISCORD_APPLICATION_ID=your_test_app_id

# OpenAI
OPENAI_API_KEY=your_openai_key

# Database - Development (used when NODE_ENV=development or unset)
# This should point to your development database (e.g., mtgrequestbot_dev)
DATABASE_URL_DEV=postgresql://user:pass@host:5432/mtgrequestbot_dev

# Database - Production (used when NODE_ENV=production)
# This should point to your production database (e.g., mtgrequestbot_prod)
DATABASE_URL_PROD=postgresql://user:pass@host:5432/mtgrequestbot_prod

# Fallback database URL (optional, for backward compatibility)
# Only used if DATABASE_URL_DEV or DATABASE_URL_PROD is not set
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Server
PORT=3000

# Environment (development or production)
# Controls which database URL is used:
# - development (or unset): uses DATABASE_URL_DEV
# - production: uses DATABASE_URL_PROD
NODE_ENV=development

# Puppeteer (set automatically in Docker, only needed for local development if Chromium path differs)
# PUPPETEER_EXECUTABLE_PATH=/path/to/chromium

# Scryfall bulk card cache (optional)
# Directory for downloaded default_cards .json.gz files (only the 3 newest are kept). Default: ./data/scryfall-bulk
# SCRYFALL_BULK_DIR=
# Cron for daily bulk download/import (default 04:00 UTC). See node-cron format.
# SCRYFALL_BULK_CRON=0 4 * * *

